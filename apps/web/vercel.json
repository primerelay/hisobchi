{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm install && pnpm --filter @hisobchi/web build",
  "outputDirectory": "dist",
  "installCommand": "npm install -g pnpm",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!assets|icons|manifest|sw|workbox).*)",
      "destination": "/index.html"
    }
  ]
}
